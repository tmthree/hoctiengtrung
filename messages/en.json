  "about": {
    "badge": "ABOUT US",
    "heading": "About",
    "intro": "Học Tiếng Trung is a free online Chinese learning platform, designed specifically for Vietnamese speakers. We believe that learning Chinese can be easier and more effective with the right approach.",
