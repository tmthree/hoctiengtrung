      "heading": "Our mission",
      "body": "We built this platform to help Vietnamese people learn Chinese systematically and at no cost. Vietnamese speakers share Sino-Vietnamese vocabulary with Chinese, giving them a unique advantage when learning the language."
    },
    "method": {
      "heading": "Learning methodology",
      "spaced": {
        "title": "Spaced Repetition (SRS)",
        "body": "Our smart flashcard system reminds you to review words at the optimal moment before forgetting, enabling long-term retention with less study time."
      },
      "hsk": {
        "title": "International HSK curriculum",
        "body": "Content follows the official HSK standards from Hanban, preparing you for official Chinese proficiency exams."
      },
      "viet": {
        "title": "Vietnamese-Chinese connections",
        "body": "Explanations from a Vietnamese perspective, highlighting relationships between Sino-Vietnamese words and modern Mandarin."
      }
    },
    "hsk": {
      "heading": "What is HSK?",
      "intro": "HSK (Hànyǔ Shuǐpíng Kǎoshì — 汉语水平考试) is the international Chinese proficiency test. It has 6 levels from beginner to advanced:",
      "level1": "~150 words · Greetings, numbers, colors",
      "level2": "~300 words · Simple everyday communication",
      "level3": "~600 words · Communication in common situations",
      "level4": "~1200 words · Basic reading comprehension",
      "level5": "~2500 words · Read newspapers, watch films without subtitles",
      "level6": "~5000 words · Full Chinese proficiency",
      "level7": "~7000 words · Politics, law, medicine, technology",
      "level8": "~9000 words · Philosophy, literature, history, science",
      "level9": "~11000 words · Near-native proficiency, classical Chinese"
    },
    "cta": {
      "heading": "Start learning today — for free!",
      "button": "Sign up for free"
    }
  },
